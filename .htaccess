<IfModule mod_rewrite.c>
RewriteEngine On

# Rewrite sitemap.xml to sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Rewrite nonexistent taxi route php files to route-page-loader.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([a-zA-Z0-9_-]+-taxi)\.php$ route-page-loader.php [L]
</IfModule>
